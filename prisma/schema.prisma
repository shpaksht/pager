generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String             @id @default(cuid())
  login        String             @unique
  passwordHash String
  createdAt    DateTime           @default(now())
  speedTests   ReadingSpeedTest[]
  books        Book[]
  readingLists ReadingList[]
  settings     UserSettings?
}

model ReadingSpeedTest {
  id            String   @id @default(cuid())
  userId        String
  textWordCount Int
  secondsSpent  Int
  wordsPerMin   Float
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Book {
  id             String      @id @default(cuid())
  userId         String
  title          String
  fileName       String
  wordCount      Int
  estimatedPages Int
  rating         Int?
  reviewComment  String?
  coverMime      String?
  coverData      Bytes?
  createdAt      DateTime    @default(now())
  plans          ReadingPlan[]
  chapters       BookChapter[]
  listEntries    ReadingListBook[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ReadingList {
  id          String            @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       ReadingListBook[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ReadingListBook {
  id        String      @id @default(cuid())
  listId    String
  bookId    String
  position  Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  list ReadingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  book Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([listId, bookId])
  @@index([listId, position])
  @@index([bookId])
}

model BookChapter {
  id        String   @id @default(cuid())
  bookId    String
  order     Int
  title     String
  href      String?
  wordCount Int
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, order])
}

model ReadingPlan {
  id                String   @id @default(cuid())
  bookId            String   @unique
  startDate         DateTime @default(now())
  monHours          Float    @default(0)
  tueHours          Float    @default(0)
  wedHours          Float    @default(0)
  thuHours          Float    @default(0)
  friHours          Float    @default(0)
  satHours          Float    @default(0)
  sunHours          Float    @default(0)
  estimatedEndDate  DateTime?
  finishedAt        DateTime?
  requiredHours     Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id       String @id @default(cuid())
  userId   String @unique
  monHours Float  @default(0)
  tueHours Float  @default(0)
  wedHours Float  @default(0)
  thuHours Float  @default(0)
  friHours Float  @default(0)
  satHours Float  @default(0)
  sunHours Float  @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
